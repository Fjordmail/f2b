{
  "name": "inboxcom/f2b",
  "description": "Fail2ban plugin for Roundcube",
  "license": "GPL-3.0-or-later",
  "type": "roundcube-plugin",
  "keywords": [
    "roundcube",
    "fail2ban",
    "security"
  ],
  "authors": [
    {
      "name": "Sebastian",
      "email": "sebastian@corp.inbox.com",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/Fjordmail/f2b/",
  "require": {
    "php": ">=8.4",
    "roundcube/plugin-installer": "~0.3.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "extra": {
    "roundcube": {
      "min-version": "1.7.0",
      "sql-dir": "./SQL",
      "persistent-files": [
        "config.inc.php"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "roundcube/plugin-installer": true
    }
  }
}
